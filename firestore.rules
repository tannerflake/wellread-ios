rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Books: read anyone; create/update when authenticated
    match /books/{bookId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // UserBooks: read/write only own (userId matches auth.uid)
    match /userBooks/{userBookId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Posts: read for feed; create when userId == auth.uid; update for likeCount/commentCount
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;  // e.g. likeCount, commentCount
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Comments: read with post; create when authenticated
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Dismissed suggestions (Pass): user can only read/write their own passed book IDs
    match /dismissedSuggestions/{docId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
